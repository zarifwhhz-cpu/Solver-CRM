# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ads_crm

# Server
PORT=5000
NODE_ENV=production

# Google Sheets Authentication (choose ONE method)

# Option 1: Google Service Account (recommended for self-hosting)
# Create a service account at https://console.cloud.google.com
# Download the JSON key file and paste its contents here (single line)
# Remember to share your Google Sheets with the service account email
GOOGLE_SERVICE_ACCOUNT_JSON=

# Facebook OAuth (for "Login with Facebook" ad account discovery)
# Create an app at https://developers.facebook.com
# Settings > Basic to get App ID and App Secret
# Add redirect URI: https://yourdomain.com/api/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Google Ads (optional — for Google Ads campaign tracking)
GOOGLE_ADS_DEVELOPER_TOKEN=

# AI Assistant (optional — configure in the app UI or set here)
# Supports: deepseek, gemini, openai, openrouter
# AI_PROVIDER=deepseek
# AI_API_KEY=
# AI_MODEL=
